generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

enum CaseMode {
  CLINICAL_QUEST
  SANEPID_INVESTIGATION
  BEST_PRACTICE
  MANAGEMENT
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  role              Role     @default(DOCTOR)
  name              String
  fullName          String?
  region            String?
  age               Int?
  specialty         String?
  phoneNumber       String?
  avatar            String?
  profilePhotoUrl   String?
  consentAcceptedAt DateTime?
  approvedAt        DateTime?
  solvedCaseIds     String[] @default([])
  unsolvedCaseIds   String[] @default([])
  medicalRecords    String?
  patientIds        String[] @default([])
  createdCases      Case[]   @relation("CaseAuthor")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([role])
  @@index([approvedAt])
}

model Case {
  id                  String      @id @default(cuid())
  authorId            String
  author              User        @relation("CaseAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  name                String
  age                 Int?
  gender              String?
  primaryCondition    String?
  history             String?
  scenarioDescription String?
  learningObjectives  String[]    @default([])
  comorbidities       String?
  subgroup            String?
  specialty           String?
  tags                String[]    @default([])
  teaser              String?
  mode                CaseMode    @default(CLINICAL_QUEST)
  body                Json        @default("{\"blocks\":[]}")
  solution            Json?
  taskQuestions       String[]    @default([])
  images              CaseImage[]
  attachments         CaseAttachment[]
  chatSessions        ChatSession[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([subgroup])
  @@index([authorId])
  @@index([mode])
}

model CaseImage {
  id       String @id @default(cuid())
  caseId   String
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  filename String
  mimeType String
  order    Int    @default(0)
  createdAt DateTime @default(now())

  @@index([caseId])
}

model Tag {
  id    String @id @default(cuid())
  label String @unique
}

model CaseAttachment {
  id        String   @id @default(cuid())
  caseId    String?
  case      Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploaderId String?
  filename  String
  originalName String?
  title     String?
  description String?
  mimeType  String
  size      Int
  kind      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([uploaderId])
}

model ChatSession {
  id          String    @id @default(cuid())
  userId      String
  caseId      String
  case        Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  phase       String    @default("discussing")
  messages    Json      @default("[]")
  finalAnswer String?
  evaluation  Json?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, caseId])
  @@index([userId])
  @@index([caseId])
}

model NewsItem {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}
