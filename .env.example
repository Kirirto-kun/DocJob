# Database
# If port 5432 is busy on your host (e.g. local Postgres), override POSTGRES_HOST_PORT
# in docker-compose (default is 5433 to avoid conflicts). Update the DATABASE_URL port accordingly.
DATABASE_URL="postgresql://docjob:docjob_dev@localhost:5433/docjob?schema=public"
POSTGRES_PASSWORD="docjob_dev"
POSTGRES_HOST_PORT="5433"

# Auth (custom JWT — @docjob/auth: argon2id passwords, keyed access-JWT, rotating refresh tokens)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Optional, only during a secret rotation: set to the OLD AUTH_SECRET after
# rotating AUTH_SECRET to a new value. Access tokens already signed with the
# old secret keep verifying (kid: 'previous') until they expire (~15m), so
# rotation doesn't force every logged-in user to re-login instantly. Remove
# this var once the old tokens have naturally expired.
# AUTH_SECRET_PREVIOUS=""

# Client-facing base URL for password-reset links (tRPC `users.requestPasswordReset`,
# packages/api/src/context.ts's `passwordResetBase`). Deliberately separate from
# AUTH_URL (which doubles as the CSRF same-origin key) — lets a mobile client
# start a reset over tRPC while the link itself still points at this web app's
# /reset-password page. Falls back to AUTH_URL, then http://localhost:3000, if unset.
# PASSWORD_RESET_URL_BASE="http://localhost:3000"

# Image uploads (local filesystem, mounted volume in docker-compose)
UPLOAD_DIR="./storage/uploads"

# OpenAI (used by case-chat-flow and structure-case-from-markdown)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1"

# Google Genkit (legacy, only if using old AI flows)
GOOGLE_API_KEY=""

# SEO — public site URL (used for canonical links, sitemap.xml, Open Graph).
# No trailing slash. In production set this to the real domain.
NEXT_PUBLIC_SITE_URL="https://docjob.kz"
# Search engine ownership verification. Paste the codes from Google Search
# Console and Yandex.Webmaster (HTML-tag verification method). Leave empty
# until you have them — empty means no verification meta tag is rendered.
GOOGLE_SITE_VERIFICATION=""
YANDEX_VERIFICATION=""

# Email (password reset). Leave RESEND_API_KEY empty in dev to log emails to the console.
# EMAIL_FROM must use a domain verified in Resend (docjob.kz is verified).
RESEND_API_KEY=""
EMAIL_FROM="DocJob <noreply@docjob.kz>"
