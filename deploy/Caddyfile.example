# /etc/caddy/Caddyfile — example for DocJob behind Caddy.
# Caddy will fetch and renew a Let's Encrypt cert automatically.
# Make sure the DNS A/AAAA record for docjob.sanduai.kz points at this server.

# If you set WEB_HOST_PORT in /opt/docjob/.env (because 3000 is busy),
# change the upstream port below to match.

docjob.sanduai.kz {
    encode zstd gzip
    reverse_proxy 127.0.0.1:3000

    # Allow large file uploads (matches the 25 MB cap in src/lib/storage.ts)
    request_body {
        max_size 30MB
    }

    header {
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        # NextAuth needs cookies; do not strip them.
    }

    log {
        output file /var/log/caddy/docjob.sanduai.kz.log
        format console
    }
}
