generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  REVIEWER
}

enum CaseMode {
  CLINICAL_QUEST
  SANEPID_INVESTIGATION
  BEST_PRACTICE
  MANAGEMENT
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  role              Role     @default(DOCTOR)
  name              String
  fullName          String?
  region            String?
  age               Int?
  specialty         String?
  phoneNumber       String?
  workplace         String?
  academicDegree    String?
  profilePhotoUrl   String?
  consentAcceptedAt DateTime?
  approvedAt        DateTime?
  createdCases      Case[]   @relation("CaseAuthor")
  savedCases        SavedCase[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens     RefreshToken[]
  reviews           Review[]
  caseSubmissions   CaseSubmission[]            @relation("SubmissionAuthor")
  submissionMessages CaseSubmissionMessage[]    @relation("SubmissionMessageSender")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([role])
  @@index([approvedAt])
}

model Case {
  id                  String      @id @default(cuid())
  authorId            String
  author              User        @relation("CaseAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  name                String
  age                 Int?
  gender              String?
  primaryCondition    String?
  history             String?
  scenarioDescription String?
  learningObjectives  String[]    @default([])
  comorbidities       String?
  subgroup            String?
  specialty           String?
  tags                String[]    @default([])
  teaser              String?
  mode                CaseMode    @default(CLINICAL_QUEST)
  body                Json        @default("{\"blocks\":[]}")
  bodyHash            String?
  embeddingDirty      Boolean     @default(true)
  embedding           Unsupported("vector(1536)")?
  searchDoc           Unsupported("tsvector")?
  images              CaseImage[]
  attachments         CaseAttachment[]
  reviews             Review[]
  savedBy             SavedCase[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([subgroup])
  @@index([authorId])
  @@index([mode])
}

model CaseImage {
  id       String @id @default(cuid())
  caseId   String
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  filename String
  mimeType String
  order    Int    @default(0)
  createdAt DateTime @default(now())

  @@index([caseId])
}

model Tag {
  id    String @id @default(cuid())
  label String @unique
}

model CaseAttachment {
  id        String   @id @default(cuid())
  caseId    String?
  case      Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploaderId String?
  filename  String
  originalName String?
  title     String?
  description String?
  mimeType  String
  size      Int
  kind      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([uploaderId])
}

model NewsItem {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model SavedCase {
  id        String   @id @default(cuid())
  userId    String
  caseId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, caseId])
  @@index([userId])
  @@index([caseId])
}

model Review {
  id         String   @id @default(cuid())
  caseId     String
  reviewerId String
  body       String   @db.Text
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  reviewer   User     @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([caseId])
  @@index([reviewerId])
}

model CaseSubmission {
  id            String                  @id @default(cuid())
  authorUserId  String
  author        User                    @relation("SubmissionAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  title         String
  description   String                  @db.Text
  authors       String[]                @default([])
  subgroup      String?
  status        String                  @default("new")
  messages      CaseSubmissionMessage[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([authorUserId])
  @@index([status])
}

model CaseSubmissionMessage {
  id           String         @id @default(cuid())
  submissionId String
  senderId     String
  submission   CaseSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  sender       User           @relation("SubmissionMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body         String         @db.Text
  attachments  Json           @default("[]")
  createdAt    DateTime       @default(now())

  @@index([submissionId])
  @@index([senderId])
}

// --- Announcements (admin advertisement popups) ---

model Announcement {
  id        String    @id @default(cuid())
  title     String
  body      String    @db.Text
  imageUrl  String?
  linkUrl   String?
  linkLabel String?
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  userId         String
  announcementId String
  createdAt      DateTime @default(now())

  @@unique([userId, announcementId])
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId     String
  tokenHash    String    @unique
  expiresAt    DateTime
  rotatedToId  String?
  replacedAt   DateTime?
  revokedAt    DateTime?
  revokeReason String?
  deviceLabel  String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
}
