# Dependencies / build output (reinstalled + rebuilt inside the image)
node_modules
**/node_modules
.next
**/.next
.turbo
**/.turbo
dist
build
coverage

# VCS / editor / OS cruft
.git
.gitignore
.vscode
.idea
.idx
.modified
.DS_Store

# Env files (passed in at `docker run` / compose time, never baked into the image).
# Blanket-ignore every .env* so a future .env.production/.env.staging can't leak
# into the build context; keep the non-secret template copyable.
.env*
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Not needed to build/run the web image
apps/mobile
docs
functions
legacy_firebase_python
dataconnect
firebase.json
firestore.rules
firestore.indexes.json
apphosting.yaml
.superpowers
.claude
README.md
CLAUDE.md

# Local uploads (persisted via a volume at runtime, not part of the image)
storage/uploads
apps/web/storage/uploads

# Tests
**/*.test.*
**/*.spec.*
